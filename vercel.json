{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "script-src 'self' 'unsafe-eval' 'unsafe-inline' https://unpkg.com https://www.gstatic.com https://cdnjs.cloudflare.com;"
        }
      ]
    }
  ],
  "functions": {
    "api/ai.js": {
      "runtime": "nodejs20.x"
    }
  }
}
